<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FAFAFA"
    tools:context=".MainActivity2">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <View
            android:id="@+id/top_background"
            android:layout_width="0dp"
            android:layout_height="280dp"
            android:background="#FFE4E1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/img_profile"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:scaleType="centerCrop"
            app:srcCompat="@drawable/profil"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/ic_notification"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="32dp"
            android:background="#FFFFFF"
            android:padding="10dp"
            android:src="@android:drawable/ic_popup_reminder"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_welcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Welcome!"
            android:textColor="#333333"
            android:textSize="18sp"
            app:layout_constraintStart_toStartOf="@id/img_profile"
            app:layout_constraintTop_toBottomOf="@id/img_profile" />

        <TextView
            android:id="@+id/tv_user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rajesh"
            android:textColor="#000000"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tv_welcome"
            app:layout_constraintTop_toBottomOf="@id/tv_welcome" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="How is it going today?"
            android:textColor="#666666"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@id/tv_user_name"
            app:layout_constraintTop_toBottomOf="@id/tv_user_name" />

        <TextView
            android:id="@+id/btn_urgent_care"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="#FF9800"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp"
            android:text="Urgent Care"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tv_subtitle"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle" />

        <ImageView
            android:id="@+id/img_doctor_main"
            android:layout_width="180dp"
            android:layout_height="230dp"
            android:layout_marginEnd="16dp"
            android:scaleType="centerCrop"
            app:srcCompat="@drawable/doctor"
            app:layout_constraintBottom_toBottomOf="@id/top_background"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_services_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:text="Our Services"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/top_background" />

        <ImageView
            android:id="@+id/ic_consultation"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginTop="16dp"
            android:background="#F0F8FF"
            android:padding="16dp"
            app:srcCompat="@drawable/appointment"
            app:layout_constraintStart_toStartOf="@id/tv_services_title"
            app:layout_constraintTop_toBottomOf="@id/tv_services_title" />

        <TextView
            android:id="@+id/tv_consultation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Consultation"
            android:textColor="#555555"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="@id/ic_consultation"
            app:layout_constraintStart_toStartOf="@id/ic_consultation"
            app:layout_constraintTop_toBottomOf="@id/ic_consultation" />

        <ImageView
            android:id="@+id/ic_medicines"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginTop="16dp"
            android:background="#F0F8FF"
            android:padding="16dp"
            app:srcCompat="@drawable/medicines"
            app:layout_constraintEnd_toStartOf="@id/ic_ambulance"
            app:layout_constraintStart_toEndOf="@id/ic_consultation"
            app:layout_constraintTop_toBottomOf="@id/tv_services_title" />

        <TextView
            android:id="@+id/tv_medicines"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Medicines"
            android:textColor="#555555"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="@id/ic_medicines"
            app:layout_constraintStart_toStartOf="@id/ic_medicines"
            app:layout_constraintTop_toBottomOf="@id/ic_medicines" />

        <ImageView
            android:id="@+id/ic_ambulance"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="24dp"
            android:background="#F0F8FF"
            android:padding="16dp"
            app:srcCompat="@drawable/ambulance"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_services_title" />

        <TextView
            android:id="@+id/tv_ambulance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Ambulance"
            android:textColor="#555555"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="@id/ic_ambulance"
            app:layout_constraintStart_toStartOf="@id/ic_ambulance"
            app:layout_constraintTop_toBottomOf="@id/ic_ambulance" />

        <TextView
            android:id="@+id/tv_appointment_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Appointment"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tv_services_title"
            app:layout_constraintTop_toBottomOf="@id/tv_consultation" />

        <TextView
            android:id="@+id/tv_see_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="See All"
            android:textColor="#2196F3"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/tv_appointment_title"
            app:layout_constraintEnd_toEndOf="@id/ic_ambulance"
            app:layout_constraintTop_toTopOf="@id/tv_appointment_title" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_appointment"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#FFFFFF"
            android:padding="16dp"
            app:layout_constraintEnd_toEndOf="@id/tv_see_all"
            app:layout_constraintStart_toStartOf="@id/tv_appointment_title"
            app:layout_constraintTop_toBottomOf="@id/tv_appointment_title">

            <TextView
                android:id="@+id/tv_app_date_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Appointment date"
                android:textColor="#999999"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/ic_clock"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginTop="8dp"
                android:src="@android:drawable/ic_menu_recent_history"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_app_date_label" />

            <TextView
                android:id="@+id/tv_app_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Wed Nov 20 • 8:00 - 8:30 AM"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/ic_clock"
                app:layout_constraintStart_toEndOf="@id/ic_clock"
                app:layout_constraintTop_toTopOf="@id/ic_clock" />

            <ImageView
                android:id="@+id/ic_more"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_more"
                app:layout_constraintBottom_toBottomOf="@id/tv_app_time"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_app_time" />

            <View
                android:id="@+id/divider"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:background="#EEEEEE"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_app_time" />

            <ImageView
                android:id="@+id/img_doc_avatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginTop="16dp"
                android:scaleType="centerCrop"
                app:srcCompat="@drawable/appointment_doctor"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider" />

            <TextView
                android:id="@+id/tv_doc_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Dr. Prem Tiwari"
                android:textColor="#000000"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/img_doc_avatar"
                app:layout_constraintTop_toTopOf="@id/img_doc_avatar" />

            <TextView
                android:id="@+id/tv_doc_spec"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Orthopedic"
                android:textColor="#888888"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="@id/tv_doc_name"
                app:layout_constraintTop_toBottomOf="@id/tv_doc_name" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>