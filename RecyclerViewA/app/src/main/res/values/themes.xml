<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.RecyclerViewA" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>
    <!-- Style untuk sudut melengkung biasa (Rounded Corners) -->
    <style name="RoundedImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item> <!-- Ubah nilai dp sesuai tingkat lengkungan yang diinginkan -->
    </style>

    <!-- Tambahan: Style untuk gambar bulat penuh (Circle) -->
    <style name="CircleImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item> <!-- 50% akan membuat gambar menjadi bulat sempurna -->
    </style>

    <style name="Theme.RecyclerViewA" parent="Base.Theme.RecyclerViewA" />
</resources>